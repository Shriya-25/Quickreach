rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── admin collection ────────────────────────────────────────────────────
    // Any signed-in user can READ their own admin doc (needed for login check)
    // Only admins can write to admin collection
    match /admin/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // ── users collection ────────────────────────────────────────────────────
    // Users can read/write their own doc EXCEPT approvalStatus
    // Admins can read/write all user docs
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isAdmin() ||
        (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approvalStatus']));
      allow delete: if isAdmin();
    }

    // ── staff collection ────────────────────────────────────────────────────
    // All approved users can read staff
    // Only admins can write
    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── reports collection ──────────────────────────────────────────────────
    // Users can read/write only their own reports
    // Admins can read/write all
    match /reports/{reportId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'adminComment', 'assignedTo']));
      allow delete: if isAdmin();
    }

    // ── alerts collection ───────────────────────────────────────────────────
    // All signed-in users can read alerts
    // Only admins can create/update/delete
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── sos_requests collection ─────────────────────────────────────────────
    // Users can create their own SOS, admins can read all
    match /sos_requests/{sosId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
